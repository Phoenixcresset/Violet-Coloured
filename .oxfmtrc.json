{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "/config",
    "/defaultconfigs",
    "/pakku*", // Generated by Pakku
    "kubejs/config", // Generated by KubeJS and Probe
    "kubejs/**/jsconfig.json", // Generated by Probe
    ".vscode/settings.json" // Formatted by Probe
  ],
  "trailingComma": "es5",
  "printWidth": 80
}
