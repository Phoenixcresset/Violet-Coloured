{
    "typescript.tsserver.maxTsServerMemory": 4096,
    "typescript.disableAutomaticTypeAcquisition": true,
    "typescript.surveys.enabled": false,
    "typescript.validate.enable": false,
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.minimap.markSectionHeaderRegex": "#region\\s*(?<separator>-?)\\s*(?<label>.*)$"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        ".gitignore": ".gitattributes",
        "package.json": ".oxfmtrc.json, .oxlintrc.json",
        "CHANGELOG.md": "CREDITS.md, LICENSE, README.md",
        "pakku.json": "pakku.jar"
    },
    "[javascript]": {
        "editor.tabSize": 2
    },
    "files.exclude": {
        ".cache/": true,
        ".mixin.out/": true,
        ".probe/": true,
        "kubejs/**/jsconfig.json": true,
        "node_modules/": true,
        "pnpm-lock.yaml": true,
        "cache/": true,
        "cherishedworlds-favorites.dat": true,
        "command_history.txt": true,
        "config/*.bak": true,
        "mods/.index/": true,
        "config/crash_assistant/modlist.json": true,
        "config/dynamic_fps.json": true,
        "config/fabric/": true,
        "config/fzzy_config/": true,
        "config/ichunutil/": true,
        "config/iris*": true,
        "config/jade/sort-order.json": true,
        "config/jei": true,
        "config/konkrete/": true,
        "config/lithium.properties": true,
        "config/lmft.json": true,
        "config/midnightlib.json": true,
        "config/modernfix-mixins.properties": true,
        "config/nerb/": true,
        "config/particle_effects.json5": true,
        "config/quark_emotes/": true,
        "config/reliable_recipes/": true,
        "config/resourceful-config-web.json": true,
        "config/sodium-fingerprint.json": true,
        "config/sodium-mixins.properties": true,
        "config/transition.json": true,
        "config/trender.json": true,
        "coremods/": true,
        "data/": true,
        "defaultconfigs/": true,
        "downloads/": true,
        "dynamic-data-pack-cache/": true,
        "dynamic-resource-pack-cache/": true,
        "emi.json": true,
        "local/": true,
        "moddata/": true,
        "saves/": true,
        "screenshots/": true,
        "server-resource-packs/": true,
        "texturepacks/": true,
        ".qmenu_opened.marker": true,
        "TrashSlotSaveState.json": true,
        "usercache.json": true,
        "usernamecache.json": true,
        "pakku-lock.json": true
    },
    "json.schemas": [
        {
            "fileMatch": [
                "/recipe_schema/*.json"
            ],
            "url": "./.vscode/recipe.json"
        }
    ]
}