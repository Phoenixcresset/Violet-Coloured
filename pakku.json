{
    "name": "Violet Coloured",
    "version": "DEV",
    "description": "A modpack made to play with Create and Spectrum together.",
    "author": "Violet Everbloom",
    "overrides": [
        "config",
        "defaultconfigs",
        "kubejs",
        "!kubejs/probe/**"
